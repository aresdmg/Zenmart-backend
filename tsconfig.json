{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipDefaultLibCheck": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}